# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gogocity

# OpenAI (required for route generation)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Google Places API (optional, for place details)
GOOGLE_PLACES_API_KEY=your_api_key_here

# App settings
DEBUG=false
